5 CALL CLEAR
10 CALL SCREEN(2)
20 REM DEFINE A SOLID BLOCK IN EACH OF 8 CHARACTER SETS
30 FOR I=0 TO 7
40 CN=96+I*8
50 CALL CHAR(CN,"FFFFFFFFFFFFFFFF")
60 NEXT I
70 REM EACH SET GETS ITS OWN FOREGROUND COLOR
80 CALL COLOR(9,9,1)
90 CALL COLOR(10,3,1)
100 CALL COLOR(11,12,1)
110 CALL COLOR(12,14,1)
120 CALL COLOR(13,5,1)
130 CALL COLOR(14,10,1)
140 CALL COLOR(15,15,1)
150 CALL COLOR(16,16,1)
160 REM DRAW 8 STRIPES, TWO ROWS EACH
170 FOR I=0 TO 7
180 CN=96+I*8
190 CALL HCHAR(5+I*2,1,CN,32)
200 CALL HCHAR(6+I*2,1,CN,32)
210 NEXT I
220 DISPLAY AT(1,10):"COLOR STRIPES"
230 CALL KEY(0,K,S)
240 IF S<1 THEN 230
250 END
